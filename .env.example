# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Crypto (ccxt / Binance by default) ---
# Only required for LIVE trading or private endpoints. Public historical
# data (fetch_ohlcv) needs no key at all.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Forex (OANDA v20 API) ---
# Free practice account + token: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true

# --- Safety gate ---
# Must be exactly "yes" before execution/crypto_live.py or
# execution/forex_live.py will place a single real order. Leave this as
# "no" until you have (a) run the backtest, (b) paper-traded for a
# meaningful stretch on live data, and (c) actually read the numbers
# rather than assumed they'd be good.
LIVE_TRADING_CONFIRMED=no
